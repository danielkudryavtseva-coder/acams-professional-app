generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  EXEC
  MEMBER
  ALUMNUS
  GUEST
}

enum Status {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum Source {
  SIGNUP
  INVITE
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  hashedPassword     String?

  role    Role    @default(MEMBER)
  status  Status  @default(UNVERIFIED)
  source  Source  @default(SIGNUP)

  verifiedAt       DateTime?
  verifiedByUserId String?
  verifiedBy       User?     @relation("UserVerifications", fields: [verifiedByUserId], references: [id])
  verifiedUsers    User[]    @relation("UserVerifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  createdInvites Invite[] @relation("InviteCreator")

  redeemedInvite Invite?

  auditLogsAsActor  AuditLog[] @relation("AuditActor")
  auditLogsAsTarget AuditLog[] @relation("AuditTarget")
}

model Invite {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  email       String
  fullName    String
  role        Role
  note        String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  usedAt      DateTime?
  revokedAt   DateTime?

  createdById String
  createdBy   User   @relation("InviteCreator", fields: [createdById], references: [id])

  redeemedUserId String? @unique
  redeemedUser   User?   @relation(fields: [redeemedUserId], references: [id])

  @@index([email])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUserId String?
  target       User?    @relation("AuditTarget", fields: [targetUserId], references: [id])
  action       String
  metadata     Json?
  at           DateTime @default(now())

  @@index([at])
  @@index([action])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
