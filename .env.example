# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Auth passwords
# These MUST be set in Vercel → Project Settings → Environment Variables.
# Without them, all login attempts will fail (the app defaults to "" which
# rejects every password check).
# ─────────────────────────────────────────────────────────────────────────────

# Shared class password shown to incoming members during recruiting.
VITE_CLASS_PASSWORD=your_class_password_here

# Secondary unlock password for the Exec Tools page (exec-only).
VITE_EXEC_PASSWORD=your_exec_password_here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Financial Modeling Prep (FMP) API key
# Powers live portfolio quotes and 1-year price history on the Portfolio page.
# Sign up free: https://site.financialmodelingprep.com/developer/docs
# Free tier: ~250 calls/day. Without this key the page shows estimated data.
# NOTE: VITE_* keys are compiled into the JS bundle and visible to anyone
# who inspects the page source — use a free-tier key with low daily limits.
# ─────────────────────────────────────────────────────────────────────────────
VITE_FMP_API_KEY=your_fmp_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Dropbox App Key
# Enables the Dropbox folder embed on the Resources page.
# Create an app: https://www.dropbox.com/developers/apps
# Add your production domain under Chooser/Saver/Embedder domains in the app settings.
# NOTE: Same bundle-visibility caveat as FMP key above.
# ─────────────────────────────────────────────────────────────────────────────
VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here
